APP_NAME=Early Literacy MVP Backend
ENVIRONMENT=local
API_V1_PREFIX=/api/v1
DATABASE_URL=change-this-access-secret
ACCESS_TOKEN_SECRET=change-this-access-secret
REFRESH_TOKEN_SECRET=change-this-refresh-secret
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=14
LOCAL_STORAGE_PATH=./local_storage
CORS_ORIGINS=["*"]

# Azure Blob Storage
AZURE_STORAGE_ACCOUNT_NAME=
AZURE_STORAGE_ACCOUNT_KEY=
# Container usado actualmente por el backend (assessment-files). Se usa tanto para
# consentimientos como para evidencias de assessments.
AZURE_STORAGE_CONTAINER_NAME=assessment-files
AZURE_STORAGE_ASSESSMENT_CONTAINER_NAME=assessment-files
AZURE_STORAGE_TEMPLATE_FOLDER=general_consent
AZURE_STORAGE_SAS_EXPIRATION_MINUTES=5
AZURE_BLOB_CONNECTION_STRING=

# Azure Vision OCR
AZURE_VISION_ENDPOINT=
AZURE_VISION_KEY=

# Azure Speech Pronunciation Assessment (dev/SPIKE)
# AZURE_SPEECH_REGION=centralus es usado por default si no se especifica.
# Pronunciation Assessment usa AZURE_SPEECH_REGION de forma explícita.
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=centralus
AZURE_SPEECH_ENDPOINT=
# Locale de Pronunciation Assessment. Para español peruano, use es-PE.
# También disponibles: es-MX, es-ES.
AZURE_SPEECH_ASSESSMENT_LOCALE=es-PE

# Local independent ASR for reading assessment
ASSESSMENT_STT_PROVIDER=faster_whisper
WHISPER_MODEL_SIZE=small
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
WHISPER_LANGUAGE=es
WHISPER_BEAM_SIZE=5
WHISPER_WORD_TIMESTAMPS=true
WHISPER_VAD_FILTER=false
WHISPER_MODEL_DOWNLOAD_ROOT=
WHISPER_LOW_CONFIDENCE_THRESHOLD=-1.0

# SMTP Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=tuemail@gmail.com
SMTP_PASSWORD=tu-contraseña-de-app
SMTP_USE_TLS=True
EMAIL_FROM=tuemail@gmail.com
